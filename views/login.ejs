<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="CET IIT Patna Admin Login - Secure access to the student management system">
  <title>CET IIT Patna | Admin Login</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <style>
    body { margin: 0; padding: 0; }

    .login-page {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #0d1b4a 0%, #1a2d6d 40%, #2a3f8f 70%, #0d1b4a 100%);
      background-size: 400% 400%;
      animation: gradientShift 12s ease infinite;
      padding: 20px;
      position: relative;
      overflow: hidden;
    }

    @keyframes gradientShift {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }

    /* Floating background shapes */
    .login-page::before,
    .login-page::after {
      content: '';
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0.15;
      animation: float 8s ease-in-out infinite;
    }

    .login-page::before {
      width: 400px; height: 400px;
      background: #ff6b35;
      top: -100px; right: -100px;
    }

    .login-page::after {
      width: 350px; height: 350px;
      background: #2ecc71;
      bottom: -80px; left: -80px;
      animation-delay: 4s;
    }

    @keyframes float {
      0%, 100% { transform: translateY(0) scale(1); }
      50% { transform: translateY(-30px) scale(1.05); }
    }

    .login-card {
      background: rgba(255, 255, 255, 0.97);
      border-radius: 24px;
      padding: 48px 40px;
      width: 100%;
      max-width: 440px;
      box-shadow:
        0 24px 80px rgba(0, 0, 0, 0.35),
        0 0 0 1px rgba(255, 255, 255, 0.1);
      text-align: center;
      position: relative;
      z-index: 2;
      animation: cardEntry 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @keyframes cardEntry {
      from { opacity: 0; transform: translateY(40px) scale(0.96); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }

    .login-logo {
      width: 72px;
      height: 72px;
      border-radius: 18px;
      object-fit: cover;
      margin-bottom: 8px;
      box-shadow: 0 4px 16px rgba(13, 27, 74, 0.15);
    }

    .login-card h1 {
      color: #0d1b4a;
      font-size: 1.75rem;
      font-weight: 700;
      margin-bottom: 4px;
      font-family: 'Outfit', sans-serif;
    }

    .login-card .subtitle {
      color: #7f8c8d;
      font-size: 0.95rem;
      margin-bottom: 32px;
    }

    .login-form .input-group {
      position: relative;
      margin-bottom: 20px;
      text-align: left;
    }

    .login-form .input-group label {
      display: block;
      font-size: 0.85rem;
      font-weight: 600;
      color: #0d1b4a;
      margin-bottom: 8px;
    }

    .login-form .input-group .input-wrapper {
      position: relative;
    }

    .login-form .input-group .input-icon {
      position: absolute;
      left: 16px;
      top: 50%;
      transform: translateY(-50%);
      color: #adb5bd;
      font-size: 1rem;
      transition: color 0.3s;
      pointer-events: none;
    }

    .login-form .input-group input {
      width: 100%;
      padding: 14px 16px 14px 46px;
      border: 2px solid #e8ecf4;
      border-radius: 12px;
      font-size: 1rem;
      font-family: 'Inter', sans-serif;
      background: #f8f9fc;
      transition: all 0.3s ease;
      color: #2c3e50;
    }

    .login-form .input-group input:focus {
      outline: none;
      border-color: #ff6b35;
      background: #fff;
      box-shadow: 0 0 0 4px rgba(255, 107, 53, 0.1);
    }

    .login-form .input-group input:focus ~ .input-icon,
    .login-form .input-group input:focus + .input-icon {
      color: #ff6b35;
    }

    .login-form .input-group input::placeholder {
      color: #c4c9d4;
    }

    .toggle-password {
      position: absolute;
      right: 16px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      cursor: pointer;
      color: #adb5bd;
      font-size: 1rem;
      transition: color 0.3s;
      padding: 4px;
    }

    .toggle-password:hover { color: #0d1b4a; }

    .login-btn {
      width: 100%;
      padding: 15px;
      background: linear-gradient(135deg, #ff6b35, #e55a2b);
      color: #fff;
      border: none;
      border-radius: 12px;
      font-size: 1.05rem;
      font-weight: 600;
      font-family: 'Outfit', sans-serif;
      cursor: pointer;
      transition: all 0.3s ease;
      margin-top: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      position: relative;
      overflow: hidden;
    }

    .login-btn:hover {
      background: linear-gradient(135deg, #e55a2b, #d04a1b);
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(255, 107, 53, 0.4);
    }

    .login-btn:active {
      transform: translateY(0);
    }

    .login-btn.loading {
      pointer-events: none;
      opacity: 0.8;
    }

    .login-btn .spinner {
      display: none;
      width: 20px;
      height: 20px;
      border: 3px solid rgba(255,255,255,0.3);
      border-top-color: #fff;
      border-radius: 50%;
      animation: spin 0.6s linear infinite;
    }

    .login-btn.loading .spinner { display: inline-block; }
    .login-btn.loading .btn-text { display: none; }

    @keyframes spin { to { transform: rotate(360deg); } }

    .login-divider {
      display: flex;
      align-items: center;
      gap: 16px;
      margin: 28px 0;
      color: #c4c9d4;
      font-size: 0.85rem;
    }

    .login-divider::before,
    .login-divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: #e8ecf4;
    }

    .login-links {
      display: flex;
      flex-direction: column;
      gap: 12px;
      align-items: center;
    }

    .login-links a {
      font-size: 0.9rem;
      color: #7f8c8d;
      transition: color 0.3s;
      text-decoration: none;
    }

    .login-links a:hover { color: #0d1b4a; }

    .login-links .register-link {
      color: #ff6b35;
      font-weight: 600;
    }

    .login-links .register-link:hover {
      color: #e55a2b;
    }

    .login-error {
      display: none;
      background: #fff5f5;
      border: 1px solid #fed7d7;
      border-radius: 10px;
      padding: 12px 16px;
      margin-bottom: 20px;
      color: #c53030;
      font-size: 0.9rem;
      font-weight: 500;
      text-align: left;
      animation: shake 0.4s ease;
    }

    .login-error.show { display: flex; align-items: center; gap: 8px; }

    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      25% { transform: translateX(-8px); }
      75% { transform: translateX(8px); }
    }

    /* Decorative dots */
    .login-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 5px;
      background: linear-gradient(90deg, #ff6b35, #2ecc71, #667eea, #ff6b35);
      border-radius: 24px 24px 0 0;
    }

    @media (max-width: 480px) {
      .login-card {
        padding: 36px 24px;
        border-radius: 20px;
      }
      .login-card h1 { font-size: 1.5rem; }
    }
  </style>
</head>
<body>

<div class="login-page">
  <div class="login-card">
    <img src="/images/logo.png" alt="CET IIT Patna Logo" class="login-logo">
    <h1>Welcome Back</h1>
    <p class="subtitle">Sign in to Admin Dashboard</p>

    <div class="login-error" id="loginError">
      <i class="fas fa-exclamation-circle"></i>
      <span id="loginErrorText">Invalid credentials</span>
    </div>

    <form class="login-form" id="loginForm" onsubmit="handleLoginSubmit(event)">
      <div class="input-group">
        <label for="login-username">Username</label>
        <div class="input-wrapper">
          <i class="fas fa-user input-icon"></i>
          <input type="text" id="login-username" name="username" required placeholder="Enter your username" autocomplete="username">
        </div>
      </div>

      <div class="input-group">
        <label for="login-password">Password</label>
        <div class="input-wrapper">
          <i class="fas fa-lock input-icon"></i>
          <input type="password" id="login-password" name="password" required placeholder="Enter your password" autocomplete="current-password">
          <button type="button" class="toggle-password" onclick="togglePass(this)">
            <i class="fas fa-eye"></i>
          </button>
        </div>
      </div>

      <button type="submit" class="login-btn" id="loginBtn">
        <span class="btn-text"><i class="fas fa-sign-in-alt"></i> Sign In</span>
        <span class="spinner"></span>
      </button>
    </form>

    <div class="login-divider">or</div>

    <div class="login-links">
      <span style="color:#7f8c8d;font-size:0.9rem;">Don't have an account? <a href="/register" class="register-link">Create Account</a></span>
      <a href="/"><i class="fas fa-arrow-left"></i> Back to Home</a>
    </div>
  </div>
</div>

<script>
  function togglePass(btn) {
    const input = btn.previousElementSibling;
    const icon = btn.querySelector('i');
    if (input.type === 'password') {
      input.type = 'text';
      icon.className = 'fas fa-eye-slash';
    } else {
      input.type = 'password';
      icon.className = 'fas fa-eye';
    }
  }

  async function handleLoginSubmit(e) {
    e.preventDefault();
    const btn = document.getElementById('loginBtn');
    const errorDiv = document.getElementById('loginError');
    const errorText = document.getElementById('loginErrorText');

    errorDiv.classList.remove('show');
    btn.classList.add('loading');

    const data = Object.fromEntries(new FormData(e.target));
    try {
      const res = await fetch('/api/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      const result = await res.json();
      if (result.success) {
        btn.innerHTML = '<i class="fas fa-check"></i> Success! Redirecting...';
        btn.style.background = 'linear-gradient(135deg, #2ecc71, #27ae60)';
        setTimeout(() => { window.location.href = '/dashboard'; }, 800);
      } else {
        errorText.textContent = result.message || 'Invalid credentials';
        errorDiv.classList.add('show');
        btn.classList.remove('loading');
      }
    } catch (err) {
      errorText.textContent = 'Connection error. Please try again.';
      errorDiv.classList.add('show');
      btn.classList.remove('loading');
    }
  }
</script>

</body>
</html>
