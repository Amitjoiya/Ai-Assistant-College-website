<!-- Eligibility -->
<section class="section section-light">
  <div class="section-title animate-on-scroll"><h2>📋 Eligibility Criteria</h2><div class="line"></div></div>
  <div style="max-width:900px;margin:auto">
    <div class="course-card animate-on-scroll" style="margin-bottom:20px;border-left-color:var(--accent)">
      <h3>💻 B.Sc CSDA / BS AICS / BS CSDA Programs</h3>
      <p class="duration" style="margin-bottom:12px">Specialization: CSDA | AI & Cyber Security</p>
      <p style="font-weight:600;color:var(--primary);margin-bottom:8px">Eligibility: 10+2 in Science with Min. 60% (Cumulative) and any one of the following:</p>
      <ul style="list-style:none;padding:0;margin:0">
        <li style="padding:8px 0;border-bottom:1px solid #eee;color:var(--text-light)">✅ Valid score/rank in National/State Level Entrance (JEE Main/Advanced, NEET, CUET, BITSAT, KVPY/NTSE/INSPIRE scholarship holders, State Entrance Examinations)</li>
        <li style="padding:8px 0;border-bottom:1px solid #eee;color:var(--text-light)">✅ Valid score in International Entrance Test — US (SAT-I/SAT-II), UK (BMAT)</li>
        <li style="padding:8px 0;color:var(--text-light)">✅ IITP-SAT entrance test followed by virtual interview</li>
      </ul>
    </div>
    <div class="course-card animate-on-scroll" style="border-left-color:#667eea">
      <h3>💼 Bachelor in Business Administration (BBA)</h3>
      <p class="duration" style="margin-bottom:12px">Business Management Stream</p>
      <p style="font-weight:600;color:var(--primary);margin-bottom:8px">Eligibility: 10+2 with Min. 60% (Cumulative) and any one of the following:</p>
      <ul style="list-style:none;padding:0;margin:0">
        <li style="padding:8px 0;border-bottom:1px solid #eee;color:var(--text-light)">✅ Valid score/rank in National/State Level Entrance (JEE Main/Advanced, NEET, CUET, BITSAT, KVPY/NTSE/INSPIRE, State Entrance Examinations)</li>
        <li style="padding:8px 0;border-bottom:1px solid #eee;color:var(--text-light)">✅ Valid score in International Entrance Test — US (SAT-I/SAT-II), UK (BMAT)</li>
        <li style="padding:8px 0;color:var(--text-light)">✅ IITP-SAT entrance test followed by virtual interview</li>
      </ul>
    </div>
  </div>
</section>

