      <div style="font-size:2.5rem;margin-bottom:8px">📚</div>
      <h3>Moodle Portal</h3>
      <p>Online Classes & Learning Management System</p>
    </a>
    <a href="https://cet.iitp.ac.in/index.php/academics/academic-calendar" target="_blank" class="course-card animate-on-scroll" style="text-decoration:none;text-align:center;cursor:pointer">
      <div style="font-size:2.5rem;margin-bottom:8px">📅</div>
      <h3>Academic Calendar</h3>
      <p>Session dates, exam schedules & events</p>
    </a>
    <a href="https://cet.iitp.ac.in/index.php/academics/time-table" target="_blank" class="course-card animate-on-scroll" style="text-decoration:none;text-align:center;cursor:pointer">
      <div style="font-size:2.5rem;margin-bottom:8px">🕐</div>
      <h3>Time Table</h3>
      <p>Class schedules & lecture timings</p>
    </a>
    <a href="https://cet.iitp.ac.in/index.php/academics/holiday-list" target="_blank" class="course-card animate-on-scroll" style="text-decoration:none;text-align:center;cursor:pointer">
      <div style="font-size:2.5rem;margin-bottom:8px">🏖️</div>
      <h3>Holiday List</h3>
      <p>Institute holidays & vacation schedule</p>
    </a>
    <a href="https://cet.iitp.ac.in/index.php/academics/end-semester-examination-schedule-spring-2026-session" target="_blank" class="course-card animate-on-scroll" style="text-decoration:none;text-align:center;cursor:pointer">
      <div style="font-size:2.5rem;margin-bottom:8px">📝</div>
      <h3>Exam Schedule</h3>
      <p>End Semester Examination Schedule (Spring 2026)</p>
    </a>
    <a href="https://cet.iitp.ac.in/index.php/e-gymkhana" target="_blank" class="course-card animate-on-scroll" style="text-decoration:none;text-align:center;cursor:pointer">
      <div style="font-size:2.5rem;margin-bottom:8px">🏅</div>
