<%- include('partials/header') %>

<!-- HERO -->
<section class="hero">
  <div class="hero-content">
    <h1>Centre for <br><span>Educational Technology</span></h1>
    <p>Empowering Education through Technology @ IIT Patna — Industry demand-driven programs in Computer Science & Business Management aligned with NEP 2020.</p>
    <div class="hero-buttons">
      <a href="/admission" class="btn btn-primary">🎓 Admission Open — Autumn 2026</a>
      <a href="/courses" class="btn btn-outline">📚 Explore Programs</a>
    </div>
  </div>
</section>

<!-- TICKER -->
<div class="ticker">
  <div class="ticker-content">
    <% if(announcements && announcements.length > 0) { %>
      <% announcements.forEach(a => { %>
        <span>📢 <%= a.title %></span>
      <% }) %>
    <% } else { %>
      <span>📢 Admission Open For Autumn 2026 Session</span>
      <span>📢 Academic Calendar for Autumn 2026 — NEW</span>
      <span>📢 End Semester Examination Schedule (Spring 2026) Released</span>
    <% } %>
  </div>
</div>

<!-- STATS -->
<section class="stats">
  <div class="stat-card animate-on-scroll">
    <div class="stat-number" data-target="<%= studentCount > 0 ? studentCount : 500 %>">0</div>
    <div class="stat-label">Students Enrolled</div>
  </div>
  <div class="stat-card animate-on-scroll">
    <div class="stat-number" data-target="50">0</div>
    <div class="stat-label">IIT Patna Faculty</div>
  </div>
  <div class="stat-card animate-on-scroll">
    <div class="stat-number" data-target="4">0</div>
    <div class="stat-label">NEP Programs</div>
  </div>
  <div class="stat-card animate-on-scroll">
    <div class="stat-number" data-target="2023">0</div>
    <div class="stat-label">Established Since</div>
  </div>
</section>

<!-- ABOUT SECTION -->
<section class="section section-light">
  <div class="section-title animate-on-scroll">
    <h2>📘 About CET, IIT Patna</h2>
    <p>Transforming education through innovative pedagogy under NEP 2020</p>
    <div class="line"></div>
  </div>
  <div style="max-width:800px;margin:auto;text-align:center" class="animate-on-scroll">
    <p style="font-size:1.05rem;line-height:1.8;color:var(--text-light)">
      IIT Patna Senate adopted the NEP-2020 and started implementing it in letter and spirit. CET is a center equipped with technology enabled platform for imparting education at affordable cost with innovative pedagogy. The curriculum is at par with globally accepted credit framework with focus on <strong>"hands-on training"</strong> and <strong>"transformative pedagogy"</strong> envisioned in NEP-2020. Program structure is flexible, modular, and suitable for both regular students and working professionals.
    </p>
    <a href="/about" class="btn btn-primary" style="margin-top:24px">Learn More →</a>
  </div>
</section>

<!-- PROGRAMS -->
<section class="section">
  <div class="section-title animate-on-scroll">
    <h2>🎓 Our Programs</h2>
    <p>Industry demand-driven programs aligned with NEP 2020</p>
    <div class="line"></div>
  </div>
  <div class="card-grid">
    <div class="course-card animate-on-scroll">
      <div class="course-icon">💻</div>
      <h3>B.Sc (Hons.) CSDA</h3>
      <p class="duration">3 Years | Modular</p>
      <p>Computer Science & Data Analytics with AI/ML specialization.</p>
      <p style="font-size:0.8rem;color:var(--secondary);margin-top:8px">10+2 Science | Min 60% | JEE/CUET/IITP-SAT</p>
      <a href="/courses" class="btn btn-primary" style="margin-top:12px;padding:8px 20px;font-size:0.85rem">Details →</a>
    </div>
    <div class="course-card animate-on-scroll">
      <div class="course-icon">🛡️</div>
      <h3>4-Year BS AICS</h3>
      <p class="duration">4 Years | Modular</p>
      <p>Artificial Intelligence & Cyber Security program.</p>
      <p style="font-size:0.8rem;color:var(--secondary);margin-top:8px">10+2 Science | Min 60% | JEE/CUET/IITP-SAT</p>
      <a href="/courses" class="btn btn-primary" style="margin-top:12px;padding:8px 20px;font-size:0.85rem">Details →</a>
    </div>
    <div class="course-card animate-on-scroll">
      <div class="course-icon">📊</div>
      <h3>4-Year BS CSDA</h3>
      <p class="duration">4 Years | Modular</p>
      <p>Extended Computer Science & Data Analytics program.</p>
      <p style="font-size:0.8rem;color:var(--secondary);margin-top:8px">10+2 Science | Min 60% | JEE/CUET/IITP-SAT</p>
      <a href="/courses" class="btn btn-primary" style="margin-top:12px;padding:8px 20px;font-size:0.85rem">Details →</a>
    </div>
    <div class="course-card animate-on-scroll">
      <div class="course-icon">💼</div>
      <h3>BBA</h3>
      <p class="duration">3 Years | Modular</p>
      <p>Bachelor in Business Administration with industry exposure.</p>
      <p style="font-size:0.8rem;color:var(--secondary);margin-top:8px">10+2 Any Stream | Min 60% | JEE/CUET/IITP-SAT</p>
      <a href="/courses" class="btn btn-primary" style="margin-top:12px;padding:8px 20px;font-size:0.85rem">Details →</a>
    </div>
  </div>
</section>

