      <p>Student activities, clubs & sports</p>
    </a>
    <a href="https://cet.iitp.ac.in/index.php/bonafide-application" target="_blank" class="course-card animate-on-scroll" style="text-decoration:none;text-align:center;cursor:pointer">
      <div style="font-size:2.5rem;margin-bottom:8px">📄</div>
      <h3>Bonafide Application</h3>
      <p>Apply for bonafide certificate online</p>
    </a>
    <a href="https://cet.iitp.ac.in/index.php/announcements/technology-club-internship-placement-cell" target="_blank" class="course-card animate-on-scroll" style="text-decoration:none;text-align:center;cursor:pointer">
      <div style="font-size:2.5rem;margin-bottom:8px">💼</div>
      <h3>Placement Cell</h3>
      <p>Technology Club & Internship opportunities</p>
    </a>
  </div>
</section>

<!-- CAMPUS -->
<section class="section">
  <div class="section-title animate-on-scroll">
    <h2>🏛️ IIT Patna Campus</h2>
    <p>World-class infrastructure at Bihta, Bihar</p>
    <div class="line"></div>
  </div>
  <div class="card-grid">
    <div class="card animate-on-scroll">
      <img src="/images/campus.jpg" alt="IIT Patna Campus">
      <div class="card-body"><h3>Green Campus</h3><p>IIT Patna campus at Bihta spread across acres of lush green environment with modern infrastructure.</p></div>
    </div>
    <div class="card animate-on-scroll">
      <img src="/images/student.jpg" alt="Student Community">
      <div class="card-body"><h3>Vibrant Community</h3><p>A diverse student community fostering collaboration, innovation and lifelong friendships.</p></div>
    </div>
    <div class="card animate-on-scroll">
      <img src="/images/education.jpg" alt="Quality Education">
      <div class="card-body"><h3>IIT Quality Education</h3><p>Curriculum designed by IIT Patna professors with industry experts ensuring the best learning outcomes.</p></div>
    </div>
  </div>
</section>

<!-- CONTACT -->
<section class="section section-light">
  <div class="section-title animate-on-scroll">
    <h2>📞 Contact CET</h2>
    <p>Get in touch with Centre for Educational Technology</p>
    <div class="line"></div>
  </div>
  <div class="contact-grid">
    <div class="contact-info animate-on-scroll">
      <h3>Centre for Educational Technology</h3>
      <div class="contact-item"><i class="fas fa-map-marker-alt"></i><span>Academic Section, Admin Block, 3rd Floor, Room No. 301</span></div>
      <div class="contact-item"><i class="fas fa-university"></i><span>IIT Patna, Bihta-801106, Bihar, India</span></div>
      <div class="contact-item"><i class="fas fa-clock"></i><span>Mon - Fri: 9:00 AM - 5:00 PM</span></div>
      <div style="margin-top:16px">
        <a href="https://registrations.iitp-cep.in/" target="_blank" class="btn btn-primary" style="padding:10px 20px;font-size:0.85rem">Official Registration Portal →</a>
      </div>
    </div>
    <div class="form-container animate-on-scroll" style="box-shadow:none">
      <form id="contactForm" onsubmit="submitContact(event)">
        <div class="form-group">
          <label>Your Name</label>
          <input type="text" class="form-control" name="name" required placeholder="Enter your name">
        </div>
        <div class="form-group">
          <label>Email Address</label>
          <input type="email" class="form-control" name="email" required placeholder="Enter your email">
        </div>
        <div class="form-group">
          <label>Message</label>
          <textarea class="form-control" name="message" required placeholder="Write your message..."></textarea>
        </div>
        <button type="submit" class="form-btn">Send Message <i class="fas fa-paper-plane"></i></button>
      </form>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
