<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="CET IIT Patna - Centre for Educational Technology | Student Management System with NEP 2020 programs in Computer Science, AI & Business Administration">
  <title>CET IIT Patna | <%= page.charAt(0).toUpperCase() + page.slice(1) %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
<nav class="navbar">
  <a href="/" class="nav-logo">
    <img src="/images/logo.png" alt="CET IIT Patna Logo">
    <span>CET IIT Patna</span>
  </a>
  <button class="nav-toggle" onclick="document.querySelector('.nav-links').classList.toggle('open')">
    <i class="fas fa-bars"></i>
  </button>
  <ul class="nav-links">
    <li><a href="/" class="<%= page==='home'?'active':'' %>"><i class="fas fa-home"></i> Home</a></li>
    <li><a href="/about" class="<%= page==='about'?'active':'' %>"><i class="fas fa-info-circle"></i> About</a></li>
    <li><a href="/courses" class="<%= page==='courses'?'active':'' %>"><i class="fas fa-book"></i> Programs</a></li>
    <li><a href="/fees" class="<%= page==='fees'?'active':'' %>"><i class="fas fa-rupee-sign"></i> Fees</a></li>
    <li><a href="/qa" class="<%= page==='qa'?'active':'' %>"><i class="fas fa-question-circle"></i> FAQ</a></li>
    <li><a href="/career" class="<%= page==='career'?'active':'' %>"><i class="fas fa-briefcase"></i> Career</a></li>
    <li><a href="/admission" class="<%= page==='admission'?'active':'' %>"><i class="fas fa-user-plus"></i> Admission</a></li>
    <% if(currentUser) { %>
      <li><a href="/dashboard" class="<%= page==='dashboard'?'active':'' %>"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
    <% } else { %>
      <li><a href="/login" class="btn btn-primary" style="padding:8px 20px;font-size:0.85rem"><i class="fas fa-lock"></i> Admin</a></li>
    <% } %>
  </ul>
</nav>
