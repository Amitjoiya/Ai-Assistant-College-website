<%- include('partials/header') %>

<section class="hero" style="height:50vh">
  <div class="hero-content">
    <h1>Admission <span>Autumn 2026</span></h1>
    <p>Apply for CET, IIT Patna Programs 🚀</p>
  </div>
</section>

<!-- Eligibility Info -->
<section class="section section-light">
  <div class="section-title animate-on-scroll"><h2>📋 Eligibility Criteria</h2><div class="line"></div></div>
  <div style="max-width:800px;margin:auto" class="animate-on-scroll">
    <div class="course-card" style="margin-bottom:16px;border-left-color:var(--accent)">
      <h3>💻 CSDA / AI & Cyber Security Programs</h3>
      <p style="margin-top:8px;color:var(--text-light)"><strong>Eligibility:</strong> 10+2 in Science with Min. 60% (Cumulative)</p>
      <p style="color:var(--text-light);font-size:0.9rem;margin-top:4px">+ Valid JEE/NEET/CUET/BITSAT/SAT score OR IITP-SAT followed by virtual interview</p>
    </div>
    <div class="course-card" style="border-left-color:#667eea">
      <h3>💼 BBA Program</h3>
      <p style="margin-top:8px;color:var(--text-light)"><strong>Eligibility:</strong> 10+2 (Any Stream) with Min. 60% (Cumulative)</p>
      <p style="color:var(--text-light);font-size:0.9rem;margin-top:4px">+ Valid JEE/NEET/CUET/BITSAT/SAT score OR IITP-SAT followed by virtual interview</p>
    </div>
  </div>
</section>

<!-- Application Form -->
<section class="section">
  <div class="form-container animate-on-scroll">
    <h2>📝 Admission Enquiry Form</h2>
    <p style="text-align:center;color:var(--text-light);margin-bottom:24px">Submit your interest — our team will contact you. For official registration, visit <a href="https://registrations.iitp-cep.in/" target="_blank" style="color:var(--secondary);font-weight:600">registrations.iitp-cep.in</a></p>
    <form id="admissionForm" onsubmit="submitAdmission(event)">
      <div class="form-row">
        <div class="form-group">
          <label>Full Name *</label>
          <input type="text" class="form-control" name="fullName" required placeholder="Enter full name">
        </div>
        <div class="form-group">
          <label>Email Address *</label>
          <input type="email" class="form-control" name="email" required placeholder="Enter email">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Phone Number *</label>
          <input type="tel" class="form-control" name="phone" required placeholder="Enter phone number">
        </div>
        <div class="form-group">
          <label>City *</label>
          <input type="text" class="form-control" name="city" required placeholder="Enter city">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Select Program *</label>
          <select class="form-control" name="course" required>
            <option value="">-- Select Program --</option>
            <option>B.Sc (Hons.) CSDA — Computer Science & Data Analytics</option>
            <option>4-Year BS — AI & Cyber Security (AICS)</option>
            <option>4-Year BS — Computer Science & Data Analytics</option>
            <option>BBA — Bachelor in Business Administration</option>
          </select>
        </div>
        <div class="form-group">
          <label>Entrance Exam Score (if any)</label>
          <input type="text" class="form-control" name="qualification" placeholder="e.g. JEE 85 percentile, CUET 650">
        </div>
      </div>
      <div class="form-group">
        <label>Additional Information</label>
        <textarea class="form-control" name="message" placeholder="Tell us about yourself, your interests, why CET IIT Patna..."></textarea>
      </div>
      <button type="submit" class="form-btn">Submit Enquiry <i class="fas fa-paper-plane"></i></button>
    </form>
  </div>
</section>

<!-- Official Links -->
<section class="section section-light" style="text-align:center">
  <h2 style="color:var(--primary);margin-bottom:16px">🔗 Official Admission Links</h2>
  <div style="display:flex;justify-content:center;gap:16px;flex-wrap:wrap;margin-top:20px">
    <a href="https://registrations.iitp-cep.in/" target="_blank" class="btn btn-primary">Official Registration →</a>
    <a href="https://cet.iitp.ac.in/index.php/admission-notice" target="_blank" class="btn btn-outline">Admission Notice →</a>
    <a href="https://cet.iitp.ac.in/index.php/announcements/brouchure" target="_blank" class="btn btn-outline">Download Brochure →</a>
  </div>
</section>

<%- include('partials/footer') %>
